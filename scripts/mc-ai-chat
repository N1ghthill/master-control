#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
LOCAL_OLLAMA="${HOME}/.local/ollama-latest/bin/ollama"

OLLAMA_BIN="ollama"
DEFAULT_MODEL="qwen3:4b-instruct-2507-q4_K_M"
DEFAULT_TIMEOUT="25"
if [[ -x "${LOCAL_OLLAMA}" ]]; then
  OLLAMA_BIN="${LOCAL_OLLAMA}"
  export OLLAMA_HOST="${OLLAMA_HOST:-127.0.0.1:11435}"
fi

exec python3 "${REPO_ROOT}/mastercontrol/interface/mc_ai.py" \
  --llm-model "${MC_LLM_MODEL:-${DEFAULT_MODEL}}" \
  --llm-timeout "${MC_LLM_TIMEOUT:-${DEFAULT_TIMEOUT}}" \
  --ollama-bin "${OLLAMA_BIN}" \
  "$@"
