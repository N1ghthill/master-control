flowchart LR
    user[Operator / Client]

    subgraph interfaces[Interfaces]
        cli[CLI]
        mcp[MCP<br/>read-only bridge]
        chat[Chat / Planner]
    end

    subgraph runtime[MC Runtime]
        core[Typed capabilities<br/>policy / approval / audit]
        state[SQLite state<br/>sessions / observations / audit / recommendations]
    end

    host[Linux Host]
    reply[Evidence / actions / audit]

    user --> cli
    user --> mcp
    user --> chat

    cli --> core
    mcp --> core
    chat --> core

    core <--> state
    core --> host
    host --> core

    core --> reply
    reply --> cli
    reply --> mcp
    reply --> chat

    classDef entry fill:#e8f3ff,stroke:#1b4d8a,stroke-width:1px,color:#10243e;
    classDef core fill:#eef8ee,stroke:#2f6b2f,stroke-width:1px,color:#102410;
    classDef data fill:#fff5e6,stroke:#8a5a12,stroke-width:1px,color:#3b2608;
    classDef output fill:#f8edf8,stroke:#7a3d7a,stroke-width:1px,color:#311231;

    class user,cli,mcp,chat entry;
    class core,host core;
    class state data;
    class reply output;
