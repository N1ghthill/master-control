flowchart TD
    user[Operator / External Client]

    subgraph interfaces[Interfaces]
        cli[CLI]
        mcp[MCP Bridge]
        chat[Chat Interface]
    end

    subgraph planning[Optional chat planning]
        provider[Planner Provider<br/>heuristic / openai / ollama]
        plan[Structured Plan<br/>plan_decision + tool steps]
        render[Chat Rendering]
    end

    subgraph runtime[MC Runtime]
        runtime_core[Runtime Core]
        ctx[Session Context + Insights]
        recs[Recommendation Queue]
        policy[Policy Engine]
        registry[Tool Registry]
        exec[Executor / OS Adapters]
    end

    subgraph state[SQLite State]
        sessions[(sessions)]
        summaries[(session_summaries)]
        observations[(observations)]
        recommendations[(session_recommendations)]
        audit[(audit_events)]
        messages[(conversation_messages)]
    end

    host[Linux Host<br/>systemd / files / proc / journal]
    approval[Approval Gate<br/>accept / --confirm]

    user --> cli --> runtime_core
    user --> mcp --> runtime_core
    user --> chat --> provider --> plan --> runtime_core

    runtime_core --> ctx
    ctx --> sessions
    ctx --> summaries
    ctx --> observations
    ctx --> recommendations
    ctx --> messages

    ctx --> recs --> recommendations

    runtime_core --> policy
    policy -->|allow| registry --> exec --> host
    policy -->|needs confirmation| approval
    approval -->|accepted| policy

    host --> exec --> runtime_core
    runtime_core --> observations
    runtime_core --> audit
    runtime_core --> summaries
    runtime_core --> messages

    runtime_core --> cli --> user
    runtime_core --> mcp --> user
    runtime_core --> render --> chat --> user

    classDef entry fill:#e8f3ff,stroke:#1b4d8a,stroke-width:1px,color:#10243e;
    classDef core fill:#eef8ee,stroke:#2f6b2f,stroke-width:1px,color:#102410;
    classDef data fill:#fff5e6,stroke:#8a5a12,stroke-width:1px,color:#3b2608;

    class user,cli,mcp,chat,approval entry;
    class provider,plan,render,runtime_core,ctx,recs,policy,registry,exec,host core;
    class sessions,summaries,observations,recommendations,audit,messages data;
